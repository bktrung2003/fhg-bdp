# Fusion BD CORE OS — Portainer Stack environment
# Copy these values into Portainer (Stack → Environment variables tab),
# replacing every <CHANGEME> with a real value.
#
# Generate strong secrets locally:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Project ─────────────────────────────────────────────────────────────────
PROJECT_NAME=Fusion BD CORE OS
TAG=latest
# Image tag to deploy. 'latest' = whatever was last pushed to main.
# For rollback, set TAG=v1.2.3 (must exist in GHCR).

# ── Public URL ──────────────────────────────────────────────────────────────
# App runs on host port 3008. Update if you change the port mapping in
# compose.portainer.yml. DOMAIN is host:port (no http://). Used for CORS.
DOMAIN=192.168.1.116:3008
FRONTEND_HOST=http://192.168.1.116:3008
BACKEND_CORS_ORIGINS=http://192.168.1.116:3008,http://localhost,http://localhost:5173

# ── Bootstrap superuser ─────────────────────────────────────────────────────
# Created on first deploy. Change the password immediately after first login.
FIRST_SUPERUSER=admin@fusionhotelgroup.com
FIRST_SUPERUSER_PASSWORD=ChangeMeOnFirstLogin!

# ── JWT secret ──────────────────────────────────────────────────────────────
# CHANGEME — generate fresh per environment. Rotating this signs out everyone.
SECRET_KEY=<CHANGEME-64-hex-chars>

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=fusion
POSTGRES_PASSWORD=<CHANGEME-strong-db-password>
POSTGRES_DB=fusion_bdp

# ── MinIO (S3-compatible storage) ───────────────────────────────────────────
# These are admin credentials for the MinIO server. Don't reuse with anything else.
MINIO_ROOT_USER=fusion_admin
MINIO_ROOT_PASSWORD=<CHANGEME-min-8-chars>
MINIO_BUCKET_DEALS=fusion-documents
# Bucket is auto-created by the 'minio-init' job on first stack deploy.

# Host ports for MinIO. This server runs many apps — default 9000/9001 are
# often taken. Pick free ports. The S3 API port must be browser-reachable
# because file downloads use presigned URLs pointing at it.
MINIO_API_PORT=3009
MINIO_CONSOLE_PORT=3010
# Public address the BROWSER uses to download files. Must be <host>:<MINIO_API_PORT>.
MINIO_PUBLIC_ENDPOINT=http://192.168.1.22:3009

# ── Email (optional — leave blank to disable) ──────────────────────────────
# When SMTP_HOST is empty, forgot-password and welcome emails are silently
# skipped and the system still works for everything else.
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
EMAILS_FROM_EMAIL=noreply@fusionhotelgroup.com
EMAILS_FROM_NAME=Fusion BD CORE OS

# ── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
