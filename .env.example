# ─── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=local

# ─── Project ──────────────────────────────────────────────────────────────────
PROJECT_NAME="Fusion BD CORE OS"
STACK_NAME=fusion-bdp

# ─── CORS ─────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-with-secrets-token_hex-32
FIRST_SUPERUSER=admin@fusionhotelgroup.com
FIRST_SUPERUSER_PASSWORD=changeme-on-first-login

# ─── Email (optional — leave SMTP_HOST blank to disable) ─────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@fusionhotelgroup.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fusion_bdp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=fusion_minio
MINIO_ROOT_PASSWORD=changeme-min-8-chars
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_DEALS=fusion-documents

# ─── Docker images ────────────────────────────────────────────────────────────
DOCKER_IMAGE_BACKEND=ghcr.io/bktrung2003/fhg-bdp/backend
DOCKER_IMAGE_FRONTEND=ghcr.io/bktrung2003/fhg-bdp/frontend

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=
